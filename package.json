{
	"name": "svelte-crossorigin-store",
	"version": "0.1.1",
	"description": "Share your Svelte store across origins, including iFrames",
	"license": "MIT",
	"type": "module",
	"exports": {
		"./iframe": {
			"import": "./dist/iframe.js",
			"types": "./dist/iframe.d.ts"
		},
		"./window": {
			"import": "./dist/window.js",
			"types": "./dist/window.d.ts"
		},
		"./broadcast": {
			"import": "./dist/broadcast.js",
			"types": "./dist/broadcast.d.ts"
		},
		"./popup": {
			"import": "./dist/popup.js",
			"types": "./dist/popup.d.ts"
		}
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"keywords": [
		"svelte",
		"svelte-store",
		"crossorigin",
		"iframe"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idleberg/svelte-crossorigin-store.git"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "npm run build -- --watch",
		"lint": "concurrently npm:lint:*",
		"lint:biome": "biome check",
		"lint:e18e": "e18e-cli analyze",
		"prepublishOnly": "npm run build",
		"start:iframe1": "cd playground && npx vite dev --strictPort --port 3031",
		"start:iframe2": "cd playground && npx vite dev --strictPort --port 3032",
		"start:main": "cd playground && npx vite dev --open --strictPort --port 3030",
		"start": "concurrently \"npm run start:iframe1\" \"npm run start:iframe2\" \"npm run start:main\"",
		"test": "vitest run",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@idleberg/configs": "^0.4.6",
		"@playwright/test": "^1.61.1",
		"@types/node": "^26.0.1",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/browser": "^4.1.9",
		"concurrently": "^10.0.3",
		"lefthook": "^2.1.9",
		"np": "^11.2.1",
		"playwright": "^1.61.1",
		"svelte": "^4.2.12",
		"tsdown": "^0.22.3",
		"tslib": "^2.6.2",
		"typescript": "^5.2.2",
		"vite": "^6.4.3",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"svelte": "^4"
	},
	"packageManager": "pnpm@10.9.0+sha512.0486e394640d3c1fb3c9d43d49cf92879ff74f8516959c235308f5a8f62e2e19528a65cdc2a3058f587cde71eba3d5b56327c8c33a97e4c4051ca48a10ca2d5f"
}
