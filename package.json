{
	"name": "svelte-crossorigin-store",
	"version": "0.1.1",
	"description": "Share your Svelte store across origins, including iFrames",
	"type": "module",
	"exports": {
		"./iframe": {
			"import": "./dist/iframe.js",
			"types": "./dist/iframe.d.ts"
		},
		"./window": {
			"import": "./dist/window.js",
			"types": "./dist/window.d.ts"
		},
		"./broadcast": {
			"import": "./dist/broadcast.js",
			"types": "./dist/broadcast.d.ts"
		},
		"./popup": {
			"import": "./dist/popup.js",
			"types": "./dist/popup.d.ts"
		}
	},
	"files": [
		"dist/",
		"LICENSE",
		"README.md"
	],
	"keywords": [
		"svelte",
		"svelte-store",
		"crossorigin",
		"iframe"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/idleberg/svelte-crossorigin-store"
	},
	"scripts": {
		"build": "tsup",
		"dev": "npm run build -- --watch",
		"prepublishOnly": "npm run lint && npm run test",
		"prepack": "npm run build",
		"start:iframe1": "cd playground && npx vite dev --strictPort --port 3031",
		"start:iframe2": "cd playground && npx vite dev --strictPort --port 3032",
		"start:main": "cd playground && npx vite dev --open --strictPort --port 3030",
		"start": "npm-run-all --parallel start:*",
		"test": "vitest run",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@types/node": "^26.0.1",
		"@vitest/browser": "^4.1.9",
		"@vitest/browser-playwright": "^4.1.9",
		"npm-run-all2": "^6.1.2",
		"playwright": "^1.61.1",
		"svelte": "^4.2.12",
		"tslib": "^2.6.2",
		"tsup": "^8.0.2",
		"typescript": "^5.2.2",
		"vite": "^6.4.3",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"svelte": "^4"
	},
	"packageManager": "pnpm@10.9.0+sha512.0486e394640d3c1fb3c9d43d49cf92879ff74f8516959c235308f5a8f62e2e19528a65cdc2a3058f587cde71eba3d5b56327c8c33a97e4c4051ca48a10ca2d5f"
}
